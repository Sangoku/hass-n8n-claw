# Local dev environment for hass-n8n-claw addon testing
# Copy to .env and fill in real values

# PostgreSQL (simulates Expaso TimescaleDB addon)
POSTGRES_DB=n8n_claw
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# n8n-claw addon options (override dev/options.json values)
ANTHROPIC_API_KEY=
N8N_ENCRYPTION_KEY=

# n8n API key — set this after first login to n8n UI
# Settings → API → Create API Key
# Then restart the n8n-claw service
N8N_API_KEY=

# Timezone
TZ=Europe/Berlin
